{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HMI Brazo SCARA",
  "version": "0.1.8",
  "identifier": "com.humanbionics.hmi-brazo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HMI Brazo SCARA",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "capabilities": ["default", "desktop-capability"]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczREUzRjdEMEJDOTZGNjIKUldSaWI4a0xmVC9lYzZYN3FVUEdHdjFjaTNUMlVBUzdGWW51Qnc5MUYwUkx3Rno3b3MwK2UvK20K",
      "endpoints": [
        "https://github.com/Miguellunab/HMI-Rotty/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
